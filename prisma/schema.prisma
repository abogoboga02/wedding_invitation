generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CLIENT
}

enum PlanTier {
  STARTER
  SIGNATURE
  STUDIO
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SendChannel {
  MANUAL
  WHATSAPP
  EMAIL
}

enum SendLogStatus {
  QUEUED
  SENT
  FAILED
}

enum InvitationTemplate {
  ELEGANT_LUXURY
  KOREAN_SOFT
  MODERN_MINIMAL
}

enum InvitationStatus {
  DRAFT
  PUBLISHED
}

enum GuestSource {
  MANUAL
  CSV
}

enum RsvpStatus {
  ATTENDING
  MAYBE
  DECLINED
}

model User {
  id            String               @id @default(cuid())
  name          String?
  email         String               @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole             @default(CLIENT)
  accounts      Account[]
  sessions      Session[]
  invitation    Invitation?
  subscriptions UserSubscription[]
  paymentOrders PaymentOrder[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invitation {
  id                String              @id @default(cuid())
  ownerId           String              @unique
  owner             User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  template          InvitationTemplate  @default(KOREAN_SOFT)
  status            InvitationStatus    @default(DRAFT)
  coupleSlug        String              @unique
  partnerOneName    String
  partnerTwoName    String
  headline          String
  subheadline       String
  story             String              @db.Text
  closingNote       String              @db.Text
  templateConfig    Json?
  coverImage        String?
  coverImageAlt     String?
  musicUrl          String?
  musicOriginalName String?
  musicMimeType     String?
  musicSize         Int?
  publishedAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  eventSlots        EventSlot[]
  galleryImages     GalleryImage[]
  guests            Guest[]
  wishes            Wish[]
  viewLogs          InvitationViewLog[]
  setting           InvitationSetting?
  sendLogs          SendLog[]
  paymentOrders     PaymentOrder[]
}

model EventSlot {
  id           String     @id @default(cuid())
  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  label        String
  startsAt     DateTime
  venueName    String
  address      String     @db.Text
  mapsUrl      String?
  latitude     Float?
  longitude    Float?
  placeName    String?
  formattedAddress String? @db.Text
  googleMapsUrl String?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([invitationId, sortOrder])
}

model GalleryImage {
  id           String     @id @default(cuid())
  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  imageUrl     String
  altText      String?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())

  @@index([invitationId, sortOrder])
}

model Guest {
  id           String      @id @default(cuid())
  invitationId String
  invitation   Invitation  @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  name         String
  guestSlug    String
  phone        String?
  email        String?
  source       GuestSource @default(MANUAL)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  rsvp         Rsvp?
  wish         Wish?
  viewLogs     InvitationViewLog[]
  sendLogs     SendLog[]

  @@unique([invitationId, guestSlug])
  @@index([invitationId, name])
}

model Rsvp {
  id          String     @id @default(cuid())
  guestId      String     @unique
  guest        Guest      @relation(fields: [guestId], references: [id], onDelete: Cascade)
  respondentName String?
  status       RsvpStatus
  attendees    Int        @default(1)
  note         String?    @db.Text
  respondedAt  DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Wish {
  id           String     @id @default(cuid())
  invitationId String
  guestId      String     @unique
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  guest        Guest      @relation(fields: [guestId], references: [id], onDelete: Cascade)
  message      String     @db.Text
  isApproved   Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([invitationId, createdAt])
}

model InvitationViewLog {
  id           String     @id @default(cuid())
  invitationId String
  guestId      String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  guest        Guest      @relation(fields: [guestId], references: [id], onDelete: Cascade)
  path         String?
  openedAt     DateTime   @default(now())

  @@index([invitationId, openedAt])
  @@index([invitationId, guestId, openedAt])
}

model InvitationSetting {
  id                   String      @id @default(cuid())
  invitationId         String      @unique
  invitation           Invitation  @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  locale               String      @default("id-ID")
  timezone             String      @default("Asia/Jakarta")
  isRsvpEnabled        Boolean     @default(true)
  isWishEnabled        Boolean     @default(true)
  autoPlayMusic        Boolean     @default(true)
  preferredSendChannel SendChannel @default(MANUAL)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

model Plan {
  id            String             @id @default(cuid())
  tier          PlanTier           @unique
  name          String
  description   String             @db.Text
  priceInIdr    Int
  isActive      Boolean            @default(true)
  sortOrder     Int                @default(0)
  subscriptions UserSubscription[]
  paymentOrders PaymentOrder[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model UserSubscription {
  id         String             @id @default(cuid())
  userId     String
  planId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan       Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  status     SubscriptionStatus @default(TRIAL)
  startsAt   DateTime           @default(now())
  expiresAt  DateTime?
  autoRenew  Boolean            @default(false)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([userId, status])
  @@index([planId, status])
}

model PaymentOrder {
  id                String        @id @default(cuid())
  userId            String
  invitationId      String?
  planId            String?
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitation        Invitation?   @relation(fields: [invitationId], references: [id], onDelete: SetNull)
  plan              Plan?         @relation(fields: [planId], references: [id], onDelete: SetNull)
  status            PaymentStatus @default(PENDING)
  amountInIdr       Int
  currency          String        @default("IDR")
  provider          String?
  externalReference String?       @unique
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([userId, status, createdAt])
  @@index([invitationId, status])
}

model SendLog {
  id                String        @id @default(cuid())
  invitationId      String
  guestId           String?
  invitation        Invitation    @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  guest             Guest?        @relation(fields: [guestId], references: [id], onDelete: SetNull)
  channel           SendChannel   @default(MANUAL)
  status            SendLogStatus @default(QUEUED)
  recipient         String
  provider          String?
  providerMessageId String?
  errorMessage      String?       @db.Text
  sentAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([invitationId, createdAt])
  @@index([guestId, createdAt])
  @@index([status, createdAt])
}
